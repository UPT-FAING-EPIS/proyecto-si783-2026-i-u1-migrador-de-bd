# Configuración de entorno para migración de bases de datos

# Credenciales de base de datos origen
BD_ORIGEN_PASSWORD=contrasena_origen_segura
BD_ORIGEN_HOST=localhost
BD_ORIGEN_PUERTO=5432
BD_ORIGEN_NOMBRE=bd_origen
BD_ORIGEN_USUARIO=usuario_origen

# Credenciales de base de datos destino
BD_DESTINO_PASSWORD=contrasena_destino_segura
BD_DESTINO_HOST=localhost
BD_DESTINO_PUERTO=5432
BD_DESTINO_NOMBRE=bd_destino
BD_DESTINO_USUARIO=usuario_destino

# Variables de bases de datos soportadas
BD_MYSQL_HOST=localhost
BD_MYSQL_PUERTO=3306
BD_MYSQL_USUARIO=root
BD_MYSQL_PASSWORD=mysql_password

BD_ORACLE_HOST=localhost
BD_ORACLE_PUERTO=1521
BD_ORACLE_SERVICIO=XE
BD_ORACLE_USUARIO=system
BD_ORACLE_PASSWORD=oracle_password

BD_SQLSERVER_HOST=localhost
BD_SQLSERVER_PUERTO=1433
BD_SQLSERVER_USUARIO=sa
BD_SQLSERVER_PASSWORD=sqlserver_password

BD_MONGODB_HOST=localhost
BD_MONGODB_PUERTO=27017
BD_MONGODB_USUARIO=admin
BD_MONGODB_PASSWORD=mongodb_password

BD_REDIS_HOST=localhost
BD_REDIS_PUERTO=6379
BD_REDIS_PASSWORD=redis_password

BD_ELASTICSEARCH_HOST=localhost
BD_ELASTICSEARCH_PUERTO=9200
BD_ELASTICSEARCH_USUARIO=elastic
BD_ELASTICSEARCH_PASSWORD=elasticsearch_password

# Configuración de sistema
ENTORNO_VIRTUAL=entorno_virtual
RUTA_ARCHIVOS_CONFIG=config/
DIRECTORIO_LOGS=logs/
DIRECTORIO_REPORTES=reportes/
DIRECTORIO_TEMPORAL=temp/

# Configuración de logging
NIVEL_LOGGING=INFO
FORMATO_LOGGING=json
ARCHIVO_LOGGING=migracion.log